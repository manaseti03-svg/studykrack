rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to ensure the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to ensure the document belongs to the requesting user
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // 1. Users collection: Locked strongly to the specific user
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // 2. Private Vault: Personal academic data
    match /private_vault/{documentId} {
      allow read, update, delete: if isAuthenticated() && resource.data.owner_uid == request.auth.uid;
      // Allow creation only if the user stamps their own UID correctly
      allow create: if isAuthenticated() && request.resource.data.owner_uid == request.auth.uid;
    }

    // 3. Global Syllabus: Community-driven academic data (Read-Only for users)
    match /global_syllabus/{documentId} {
      allow read: if isAuthenticated();
      allow write: if false; // System only
    }

    // 4. System Metrics: Audit trails (No client access)
    match /system_metrics/{documentId} {
      allow read, write: if false;
    }

    // 5. Leaderboard & Stats
    match /leaderboard/{documentId} {
      allow read: if isAuthenticated();
      allow write: if false; // Managed by backend functions
    }
    
    // Catch-all: Deny everything else
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
