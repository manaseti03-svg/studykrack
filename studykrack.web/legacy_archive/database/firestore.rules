rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is accessing their own data
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Sessions Rules
    match /sessions/{sessionId} {
      allow read, write, delete: if isAuthenticated() && isOwner(resource.data.userId || request.resource.data.userId);

      // Messages Subcollection Rules
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && 
          isOwner(get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId);
      }
    }
  }
}
